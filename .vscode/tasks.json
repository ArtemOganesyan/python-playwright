{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Record Python Playwright test",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "record.py",
        "https://nop-qa.portnov.com/",
        "--output",
        "tests/recorded_test.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}

